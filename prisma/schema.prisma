generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  password    String
  name        String?
  apiKeys     ApiKey[]
  projects    Project[]
  generations Generation[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model ApiKey {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String
  encryptedKey String
  iv           String
  authTag      String
  model        String
  baseUrl      String?
  label        String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Project {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  website     String?
  generations Generation[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Generation {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  toolType   String
  inputs     String
  output     String
  promptUsed String?
  provider   String
  model      String
  tokensUsed Int?
  isFavorite Boolean  @default(false)
  createdAt  DateTime @default(now())
}
